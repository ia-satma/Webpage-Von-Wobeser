# Plantilla de variables de entorno. Copiar a .env y completar.
# En Replit estas variables las inyecta el entorno (Secrets / AI Integrations); este archivo es para correr local.

# --- Base de datos (requerido) ---
# Local: Postgres propio. Replit: Neon serverless (el código detecta el driver automáticamente).
DATABASE_URL=postgresql://localhost:5432/vonwobeser_dev

# --- Servidor ---
PORT=5000
NODE_ENV=development
# Origen permitido para CORS. Si no se define, el server falla cerrado (no usa wildcard).
CORS_ORIGIN=http://localhost:5000

# --- OpenAI / IA (opcional en local) ---
# En Replit: AI_INTEGRATIONS_OPENAI_BASE_URL + AI_INTEGRATIONS_OPENAI_API_KEY (modelo gpt-5).
# En local: basta OPENAI_API_KEY estándar; sin ella, las features de IA se deshabilitan con gracia.
OPENAI_API_KEY=
# Sobreescribe el modelo de traducción (gpt-5 solo funciona con las AI Integrations de Replit).
OPENAI_TRANSLATE_MODEL=gpt-4o

# --- Gemini (opcional, fallback de generación de imágenes) ---
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=

# --- pCloud (opcional, persistencia de conocimiento de agentes) ---
PCLOUD_USERNAME=
PCLOUD_PASSWORD=

# --- Admin bootstrap (opcional; el seed crea el primer super_admin si están presentes) ---
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
